# Required Backblaze credentials
BACKBLAZE_KEY_ID=your_backblaze_key_id
BACKBLAZE_APPLICATION_KEY=your_backblaze_application_key
BACKBLAZE_BUCKET_ID=your_backblaze_bucket_id
BACKBLAZE_BUCKET_NAME=your_backblaze_bucket_name

# Optional: require this bearer token from frontend signer request
BACKBLAZE_SIGN_TOKEN=choose_a_strong_random_token

# Optional: comma-separated allowlist for browser origins.
# Leave empty to allow all origins.
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
